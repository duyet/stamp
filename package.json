{
	"name": "stamp",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"dev:cf": "opennextjs-cloudflare build && wrangler dev",
		"build": "next build",
		"start": "next start",
		"preview": "opennextjs-cloudflare build && wrangler dev",
		"deploy": "opennextjs-cloudflare build && wrangler deploy",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply stamp-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply stamp-db --remote",
		"db:studio": "drizzle-kit studio",
		"setup": "./scripts/setup.sh",
		"setup:remote": "./scripts/setup.sh --remote",
		"setup:ci": "./scripts/setup-ci-secrets.sh",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.17.1",
		"drizzle-orm": "^0.45.1",
		"nanoid": "^5.1.7",
		"next": "16.1.6",
		"react": "19.2.3",
		"react-dom": "19.2.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@cloudflare/workers-types": "^4.20260316.1",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"drizzle-kit": "^0.31.9",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vitest": "^4.1.0",
		"wrangler": "^4.73.0"
	}
}
