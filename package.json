{
	"name": "stamp",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bash -lc 'set -a; for f in .env .env.local .env.development .env.development.local; do [ -f \"$f\" ] && source \"$f\"; done; set +a; vite dev \"$@\"' --",
		"dev:cf": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "bash -lc 'set -a; for f in .env .env.local .env.production .env.production.local; do [ -f \"$f\" ] && source \"$f\"; done; set +a; vite build && wrangler deploy \"$@\"' --",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"fmt": "biome format --write .",
		"format": "biome format --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply stamp-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply stamp-db --remote",
		"db:studio": "drizzle-kit studio",
		"setup": "./scripts/setup.sh",
		"setup:remote": "./scripts/setup.sh --remote",
		"setup:ci": "./scripts/setup-ci-secrets.sh",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@clerk/tanstack-react-start": "^1.0.7",
		"@cloudflare/vite-plugin": "^1.30.1",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-router": "^1.168.5",
		"@tanstack/react-start": "^1.167.9",
		"@vitejs/plugin-react": "^6.0.1",
		"drizzle-orm": "^0.45.1",
		"nanoid": "^5.1.7",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"vite": "^8.0.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@cloudflare/workers-types": "^4.20260316.1",
		"@types/node": "^25.0.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"drizzle-kit": "^0.31.9",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vitest": "^4.1.0",
		"wrangler": "^4.73.0"
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
